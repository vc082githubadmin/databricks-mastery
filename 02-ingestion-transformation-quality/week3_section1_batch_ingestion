# ── BLOCK 6: Read with explicit schema + corrupt record handling
# Explicit schema ignores extra columns (discount_code in day2)
# PERMISSIVE mode captures bad rows without failing the pipeline

order_schema = StructType([
    StructField("order_id",    IntegerType(), nullable=False),
    StructField("customer_id", StringType(),  nullable=True),
    StructField("amount",      DoubleType(),  nullable=True),
    StructField("order_date",  DateType(),    nullable=True),
    StructField("status",      StringType(),  nullable=True),
    StructField("_corrupt_record", StringType(), nullable=True)
])

df_raw = spark.read \
    .format("csv") \
    .schema(order_schema) \
    .option("header", "true") \
    .option("nullValue", "NULL") \
    .option("mode", "PERMISSIVE") \
    .option("columnNameOfCorruptRecord", "_corrupt_record") \
    .load("dbfs:/tmp/landing/orders/")

print("\n=== Raw read — all rows including corrupt ===")
df_raw.show()

# Separate clean from corrupt
clean_orders = df_raw.filter(col("_corrupt_record").isNull()) \
                     .drop("_corrupt_record")

corrupt_orders = df_raw.filter(col("_corrupt_record").isNotNull())

print(f"\nClean records: {clean_orders.count()}")
print(f"Corrupt records: {corrupt_orders.count()}")

print("\n=== Clean orders ===")
clean_orders.show()

print("\n=== Corrupt records (quarantined) ===")
corrupt_orders.select("_corrupt_record").show(truncate=False)

# OBSERVE:
# order_id 103 has amount = "INVALID" — cannot cast to DoubleType
# It appears in _corrupt_record column — pipeline doesn't fail
# day2 file has discount_code column — silently ignored by explicit schema
# clean_orders has 4 records, corrupt_orders has 1




