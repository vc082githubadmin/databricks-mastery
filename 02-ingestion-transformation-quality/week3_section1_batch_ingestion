# ── BLOCK 7: FAILFAST mode demonstration ─────────────────────
# Shows how FAILFAST stops on the first corrupt record

print("\n=== FAILFAST mode — fails on first corrupt record ===")
try:
    df_strict = spark.read \
        .format("csv") \
        .schema(order_schema.fields[:-1])  \
        .option("header", "true") \
        .option("mode", "FAILFAST") \
        .load("dbfs:/tmp/landing/orders/orders_day1.csv")
    df_strict.show()
except Exception as e:
    print(f"FAILFAST caught error (expected): {type(e).__name__}")
    print("Pipeline stopped on first corrupt record")
    print("Use FAILFAST when data must be perfect — zero tolerance for bad records")

print("\n=== Read modes summary ===")
print("PERMISSIVE  — capture bad rows in _corrupt_record, continue")
print("DROPMALFORMED — silently skip bad rows, continue")
print("FAILFAST    — stop immediately on first bad row")
