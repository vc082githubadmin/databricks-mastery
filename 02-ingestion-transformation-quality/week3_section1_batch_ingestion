# ── BLOCK 1: Setup ───────────────────────────────────────────
# Create simulated source data representing a relational database
# and file-based landing zone

spark.sql("DROP TABLE IF EXISTS default.source_transactions")
spark.sql("DROP TABLE IF EXISTS default.source_customers")
spark.sql("DROP TABLE IF EXISTS default.bronze_transactions")
spark.sql("DROP TABLE IF EXISTS default.ingestion_control")

from pyspark.sql.functions import col, to_timestamp, max as spark_max
from pyspark.sql.types import (StructType, StructField, IntegerType,
                                StringType, DoubleType, DateType,
                                TimestampType)
# Simulate source database tables
transactions_data = [
    (1,  "C001", 999.99,  "2024-01-15", "completed", "2024-01-15 08:00:00"),
    (2,  "C002", 699.99,  "2024-01-15", "completed", "2024-01-15 08:05:00"),
    (3,  "C001", 499.99,  "2024-01-16", "pending",   "2024-01-16 09:00:00"),
    (4,  "C003", 299.99,  "2024-01-16", "completed", "2024-01-16 09:10:00"),
    (5,  "C002", 149.99,  "2024-01-17", "completed", "2024-01-17 10:00:00"),
]

spark.createDataFrame(
    transactions_data,
    ["txn_id", "customer_id", "amount", "txn_date", "status", "updated_at"]
).write.format("delta").mode("overwrite") \
 .saveAsTable("default.source_transactions")

print("=== Source transactions table ===")
spark.sql("SELECT * FROM default.source_transactions ORDER BY txn_id").show()

# Create ingestion control table — tracks watermarks per source table
spark.sql("""
    CREATE TABLE default.ingestion_control (
        table_name                STRING,
        last_processed_timestamp  TIMESTAMP
    ) USING DELTA
""")

spark.sql("""
    INSERT INTO default.ingestion_control VALUES
    ('source_transactions', '2024-01-15 00:00:00')
""")

print("\n=== Ingestion control (initial watermark) ===")
spark.sql("SELECT * FROM default.ingestion_control").show()

# COMMAND ----------


# ── BLOCK 2: Full load — first ingestion ─────────────────────
# First run: load everything up to the current watermark
# Simulates the initial historical load pattern

watermark = spark.sql("""
    SELECT last_processed_timestamp
    FROM default.ingestion_control
    WHERE table_name = 'source_transactions'
""").collect()[0][0]

print(f"\n=== Full load — watermark: {watermark} ===")

# Read all records after the watermark
initial_load = spark.sql(f"""
    SELECT * FROM default.source_transactions
    WHERE updated_at > '{watermark}'
""")

print(f"Records to ingest: {initial_load.count()}")
initial_load.show()

# Write to Bronze
initial_load.write.format("delta") \
            .mode("append") \
            .saveAsTable("default.bronze_transactions")

# Update watermark to maximum updated_at in this batch
new_watermark = initial_load.agg(
    spark_max("updated_at").alias("max_ts")
).collect()[0][0]

spark.sql(f"""
    UPDATE default.ingestion_control
    SET last_processed_timestamp = '{new_watermark}'
    WHERE table_name = 'source_transactions'
""")

print(f"\n=== Watermark updated to: {new_watermark} ===")
spark.sql("SELECT * FROM default.ingestion_control").show()




# COMMAND ----------

# ── BLOCK 3: Simulate new records arriving ───────────────────
# Add new transactions to the source table
# These represent records that arrived after the last pipeline run

new_transactions = spark.createDataFrame([
    (6, "C001", 1299.99, "2024-01-18", "completed", "2024-01-18 08:00:00"),
    (7, "C003", 89.99,   "2024-01-18", "pending",   "2024-01-18 08:30:00"),
    (8, "C002", 449.99,  "2024-01-19", "completed", "2024-01-19 09:00:00"),
],
["txn_id", "customer_id", "amount", "txn_date", "status", "updated_at"])

new_transactions.write.format("delta") \
                .mode("append") \
                .saveAsTable("default.source_transactions")

print("\n=== Source now has 8 records (3 new) ===")
spark.sql("""
    SELECT * FROM default.source_transactions ORDER BY txn_id
""").show()




# COMMAND ----------

# ── BLOCK 4: Incremental load — watermark pattern ────────────
# Second run: only load records newer than the last watermark
# This is the core incremental ingestion pattern

current_watermark = spark.sql("""
    SELECT last_processed_timestamp
    FROM default.ingestion_control
    WHERE table_name = 'source_transactions'
""").collect()[0][0]

print(f"\n=== Incremental load — watermark: {current_watermark} ===")

incremental_batch = spark.sql(f"""
    SELECT * FROM default.source_transactions
    WHERE updated_at > '{current_watermark}'
""")

print(f"New records since last run: {incremental_batch.count()}")
incremental_batch.show()

# Write only new records to Bronze
incremental_batch.write.format("delta") \
                 .mode("append") \
                 .saveAsTable("default.bronze_transactions")

# Update watermark
new_watermark = incremental_batch.agg(
    spark_max("updated_at").alias("max_ts")
).collect()[0][0]

spark.sql(f"""
    UPDATE default.ingestion_control
    SET last_processed_timestamp = '{new_watermark}'
    WHERE table_name = 'source_transactions'
""")

print(f"\n=== Watermark updated to: {new_watermark} ===")

print("\n=== Bronze table — all ingested records ===")
spark.sql("""
    SELECT * FROM default.bronze_transactions ORDER BY txn_id
""").show()

# OBSERVE: Bronze has 8 records total
# First run ingested 5 records, second run ingested 3
# No full table scan on second run — only new records processed




